<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16.dp"
    android:layout_marginVertical="8.dp"
    android:background="@drawable/mid_fi_card">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16.dp">

        <TextView
            android:id="@+id/textViewCourseCode"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Material3.LabelMedium"
            android:textColor="@color/brand"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="CSIT284" />

        <TextView
            android:id="@+id/textViewCourseName"
            android:layout_width="0.dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4.dp"
            android:textAppearance="@style/TextAppearance.Material3.TitleLarge"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@+id/badgeLive"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewCourseCode"
            tools:text="Distributed Systems" />

        <TextView
            android:id="@+id/textViewStudentCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8.dp"
            android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
            android:textColor="@color/border"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/textViewCourseName"
            tools:text="42 Students" />

        <LinearLayout
            android:id="@+id/badgeLive"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@color/live_red_alpha"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="8.dp"
            android:paddingVertical="4.dp"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="@id/textViewCourseName"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/textViewCourseName"
            tools:visibility="visible">

            <View
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:background="@drawable/shape_dot_live" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6.dp"
                android:text="LIVE"
                android:textAppearance="@style/TextAppearance.Material3.LabelSmall"
                android:textColor="@color/live_red"
                android:textStyle="bold" />
        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</FrameLayout>
